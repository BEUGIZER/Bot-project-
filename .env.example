# Discord bot application credentials (Discord Developer Portal)
DISCORD_TOKEN=your-bot-token-here
CLIENT_ID=your-application-id-here

# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/discordbot

# Comma-separated Discord user IDs allowed to run owner-only CLI scripts (not currently enforced in-bot,
# reserved for future use / your own reference)
OWNER_IDS=

# How many commands a server can have active at once
FREE_SLOT_LIMIT=5
PREMIUM_SLOT_LIMIT=25

# Optional: get a free key at https://klipy.com/developers to enable real
# GIFs on /hug, /slap, etc. Leave blank and they fall back to plain text.
# (Tenor is not used — Google stopped issuing new Tenor API keys in Jan 2026
# and shut the API down entirely on June 30, 2026.)
KLIPY_API_KEY=
